{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "dockerfilePath": "py-mekai-api/Dockerfile"
  },
  "deploy": {
    "startCommand": "uvicorn main:app --host 0.0.0.0 --port ${PORT:-5100} --workers 1 --log-level info",
    "healthcheckPath": "/",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
